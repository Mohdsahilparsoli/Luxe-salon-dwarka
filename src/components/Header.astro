---

import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
  <div class="container header-inner">
    <HeaderLink href="/" class="logo">
      <span class="mark"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg></span>
      <span><strong>Luxe Salon</strong><span>Dwarka &middot; New Delhi</span></span>
    </HeaderLink>
    <nav class="main-nav" aria-label="Primary">
      <ul>
        <li><HeaderLink href="/" >Home</HeaderLink></li>
        <li><HeaderLink href="/about">About</HeaderLink></li>
        <li><HeaderLink href="/services">Services</HeaderLink></li>
        <li><HeaderLink href="/gallery">Gallery</HeaderLink></li>
        <li><HeaderLink href="/pricing">Pricing</HeaderLink></li>
        <li><HeaderLink href="/contact">Contact</HeaderLink></li>
      </ul>
    </nav>
    <div class="header-actions">
      <HeaderLink href="/contact#book" class="btn btn-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Book Appointment</HeaderLink>
      <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="icon-open"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg></span>
        <span class="icon-close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
      </button>
    </div>
  </div>
  <div class="mobile-nav">
    <ul>
      <li><HeaderLink href="/">Home</HeaderLink></li>
      <li><HeaderLink href="/about">About</HeaderLink></li>
      <li><HeaderLink href="/services">Services</HeaderLink></li>
      <li><HeaderLink href="/gallery">Gallery</HeaderLink></li>
      <li><HeaderLink href="/pricing">Pricing</HeaderLink></li>
      <li><HeaderLink href="/contact">Contact</HeaderLink></li>
    </ul>
    <HeaderLink href="/contact#book" class="btn btn-primary block">Book Appointment</HeaderLink>
  </div>
</header>
