---
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="Services | Hair, Beauty  Makeup | Luxe Salon Dwarka"
	description="Explore hair, beauty and makeup services at Luxe Salon Dwarka — haircuts, colouring, keratin, facials, waxing, threading, bridal and party makeup in Dwarka, New Delhi."
	pubDate={new Date('August 08 2021')}
	heroImage={AboutHeroImage}
>
<main>

  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Our Services</span>
      <h1>Hair, beauty and makeup — done with intention.</h1>
      <p class="lede">Every service starts with a short consultation, so what you get matches what you actually asked for. Browse our menu below, then book online or by phone.</p>
    </div>
  </section>

  <!-- HAIR SERVICES -->
  <section class="section" id="hair">
    <div class="container">
      <div class="section-head">
        <svg class="part-line" viewBox="0 0 64 20"><path d="M2 16 Q 20 2, 32 10 T 62 6"/></svg>
        <span class="eyebrow">Hair Services</span>
        <h2>Cut, coloured and conditioned to last</h2>
      </div>
      <div class="grid grid-3">
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg></span>
          <h3>Haircut</h3>
          <p>Precision cutting tailored to your face shape, hair texture and how much time you actually spend styling.</p>
          <a href="/pricing#hair-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8L4 11l6.1 2.2L12 19l1.9-5.8L20 11l-6.1-2.2Z"/></svg></span>
          <h3>Hair Styling</h3>
          <p>Blow-dry, curls, updos and event styling using heat-protected techniques that keep hair healthy.</p>
          <a href="/pricing#hair-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 12L2 9Z"/><path d="M11 3 8 9l4 12 4-12-3-6"/><path d="M2 9h20"/></svg></span>
          <h3>Hair Colouring</h3>
          <p>Global colour, balayage, highlights and grey coverage with ammonia-free, long-lasting formulas.</p>
          <a href="/pricing#hair-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69s-5 5.9-5 9.86a5 5 0 0 0 10 0c0-3.97-5-9.86-5-9.86Z"/></svg></span>
          <h3>Hair Spa</h3>
          <p>Deep-conditioning scalp and strand therapy that restores moisture, shine and manageability.</p>
          <a href="/pricing#hair-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
          <h3>Keratin Treatment</h3>
          <p>Smoothing treatment that cuts frizz and blow-dry time for up to four months.</p>
          <a href="/pricing#hair-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BEAUTY SERVICES -->
  <section class="section tint" id="beauty">
    <div class="container">
      <div class="section-head">
        <svg class="part-line" viewBox="0 0 64 20"><path d="M2 16 Q 20 2, 32 10 T 62 6"/></svg>
        <span class="eyebrow">Beauty Services</span>
        <h2>Skin and grooming, dermatologist-informed</h2>
      </div>
      <div class="grid grid-3">
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
          <h3>Facial</h3>
          <p>Skin-specific facials for hydration, brightening or anti-ageing, chosen after a quick skin analysis.</p>
          <a href="/pricing#beauty-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15a7 7 0 1 0 0-14 7 7 0 0 0 0 14Z"/><path d="m9 11 2 2 4-4"/></svg></span>
          <h3>Cleanup</h3>
          <p>A quick refresh treatment for exfoliation and glow — ideal before events or as a monthly reset.</p>
          <a href="/pricing#beauty-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8L4 11l6.1 2.2L12 19l1.9-5.8L20 11l-6.1-2.2Z"/></svg></span>
          <h3>Waxing</h3>
          <p>Full-body and precision waxing using low-irritation, dermatologically tested wax.</p>
          <a href="/pricing#beauty-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
          <h3>Threading</h3>
          <p>Precise brow and facial threading, shaped to suit your features.</p>
          <a href="/pricing#beauty-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
        <div class="card reveal">
          <span class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 12L2 9Z"/><path d="M11 3 8 9l4 12 4-12-3-6"/><path d="M2 9h20"/></svg></span>
          <h3>Skin Treatments</h3>
          <p>Targeted treatments for pigmentation, acne marks and dullness, planned over multiple sessions.</p>
          <a href="/pricing#beauty-pricing" class="btn small btn-ghost" style="margin-top:18px;">See Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAKEUP SERVICES -->
  <section class="section" id="makeup">
    <div class="container">
      <div class="section-head">
        <svg class="part-line" viewBox="0 0 64 20"><path d="M2 16 Q 20 2, 32 10 T 62 6"/></svg>
        <span class="eyebrow">Makeup Services</span>
        <h2>Makeup that photographs as well as it looks</h2>
      </div>
      <div class="grid grid-3">
        <div class="service-card reveal">
          <img src="https://images.unsplash.com/photo-1607779097040-26e80aa78e66?auto=format&fit=crop&w=500&q=80" alt="Bridal makeup look created at Luxe Salon Dwarka" loading="lazy">
          <div class="content"><span class="tag">Bridal</span><h3>Bridal Makeup</h3><p>Full bridal look with trial session included</p></div>
        </div>
        <div class="service-card reveal">
          <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&w=500&q=80" alt="Party makeup application for an evening event" loading="lazy">
          <div class="content"><span class="tag">Party</span><h3>Party Makeup</h3><p>Event-ready looks for functions and parties</p></div>
        </div>
        <div class="service-card reveal">
          <img src="https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1?auto=format&fit=crop&w=500&q=80" alt="HD makeup application under studio lighting" loading="lazy">
          <div class="content"><span class="tag">HD</span><h3>HD Makeup</h3><p>Camera-ready finish for shoots and receptions</p></div>
        </div>
      </div>
      <div style="text-align:center;margin-top:44px;">
        <a href="/pricing#bridal" class="btn btn-dark">View Bridal Packages<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section tint">
    <div class="container">
      <div class="cta-band reveal">
        <svg class="strands" viewBox="0 0 800 300" preserveAspectRatio="none"><path d="M0 250 Q 200 150 400 220 T 800 180" stroke="#2DD4BF" stroke-width="1.5" fill="none"/><path d="M0 90 Q 220 40 420 110 T 800 60" stroke="#2DD4BF" stroke-width="1.5" fill="none"/></svg>
        <div class="cta-band-inner">
          <div>
            <h2>Not sure which service fits you?</h2>
            <p>Call us and describe what you're after — we'll recommend the right service and stylist.</p>
          </div>
          <div class="cta-actions">
            <a href="/contact#book" class="btn btn-primary">Book Appointment</a>
            <a href="/tel:+911145678900" class="btn btn-outline">Call Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>
</Layout>
