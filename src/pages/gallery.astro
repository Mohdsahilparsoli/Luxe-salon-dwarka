---
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="Gallery | Luxe Salon Dwarka"
	description="Browse hair transformations, bridal looks, beauty treatments and salon interiors from Luxe Salon Dwarka, New Delhi."
	pubDate={new Date('August 08 2021')}
	heroImage={AboutHeroImage}
>
<main>

  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Gallery</span>
      <h1>A closer look at the work.</h1>
      <p class="lede">Hair transformations, bridal looks, beauty treatments and the studio itself — filter by category or browse it all.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">

      <div class="gallery-filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="hair">Hair Transformations</button>
        <button class="filter-btn" data-filter="bridal">Bridal Gallery</button>
        <button class="filter-btn" data-filter="beauty">Beauty Treatments</button>
        <button class="filter-btn" data-filter="interior">Salon Interior</button>
        <button class="filter-btn" data-filter="results">Client Results</button>
      </div>

      <div class="masonry">
        <div class="masonry-item" data-category="hair">
          <img src="https://images.unsplash.com/photo-1522337660859-02fbefca4702?auto=format&fit=crop&w=600&q=80" alt="Layered haircut transformation at Luxe Salon Dwarka" loading="lazy">
          <div class="overlay"><span>Hair Transformation</span></div>
        </div>
        <div class="masonry-item" data-category="bridal">
          <img src="https://images.unsplash.com/photo-1607779097040-26e80aa78e66?auto=format&fit=crop&w=600&q=80" alt="Bridal makeup and hairstyle look" loading="lazy">
          <div class="overlay"><span>Bridal Look</span></div>
        </div>
        <div class="masonry-item" data-category="interior">
          <img src="https://images.unsplash.com/photo-1633681926035-ec1ac984418a?auto=format&fit=crop&w=600&q=80" alt="Reception area at Luxe Salon Dwarka" loading="lazy">
          <div class="overlay"><span>Salon Interior</span></div>
        </div>
        <div class="masonry-item" data-category="beauty">
          <img src="https://images.unsplash.com/photo-1580618672591-eb180b1a973f?auto=format&fit=crop&w=600&q=80" alt="Facial treatment session at Luxe Salon Dwarka" loading="lazy">
          <div class="overlay"><span>Beauty Treatment</span></div>
        </div>
        <div class="masonry-item" data-category="hair">
          <img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?auto=format&fit=crop&w=600&q=80" alt="Balayage colour transformation" loading="lazy">
          <div class="overlay"><span>Hair Transformation</span></div>
        </div>
        <div class="masonry-item" data-category="results">
          <img src="https://images.unsplash.com/photo-1600948836101-f9ffda59d250?auto=format&fit=crop&w=600&q=80" alt="Client hair colour result" loading="lazy">
          <div class="overlay"><span>Client Result</span></div>
        </div>
        <div class="masonry-item" data-category="interior">
          <img src="https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?auto=format&fit=crop&w=600&q=80" alt="Styling floor at Luxe Salon Dwarka" loading="lazy">
          <div class="overlay"><span>Salon Interior</span></div>
        </div>
        <div class="masonry-item" data-category="bridal">
          <img src="https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1?auto=format&fit=crop&w=600&q=80" alt="HD bridal makeup application" loading="lazy">
          <div class="overlay"><span>Bridal Gallery</span></div>
        </div>
        <div class="masonry-item" data-category="beauty">
          <img src="https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?auto=format&fit=crop&w=600&q=80" alt="Threading and waxing beauty treatment" loading="lazy">
          <div class="overlay"><span>Beauty Treatment</span></div>
        </div>
        <div class="masonry-item" data-category="hair">
          <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&w=600&q=80" alt="Precision haircut close up" loading="lazy">
          <div class="overlay"><span>Hair Transformation</span></div>
        </div>
        <div class="masonry-item" data-category="results">
          <img src="https://images.unsplash.com/photo-1595473465036-52c0a3f39c7c?auto=format&fit=crop&w=600&q=80" alt="Client hair after keratin treatment" loading="lazy">
          <div class="overlay"><span>Client Result</span></div>
        </div>
        <div class="masonry-item" data-category="interior">
          <img src="https://images.unsplash.com/photo-1470259078422-826894b933aa?auto=format&fit=crop&w=600&q=80" alt="Salon interior with styling chairs" loading="lazy">
          <div class="overlay"><span>Salon Interior</span></div>
        </div>
        <div class="masonry-item" data-category="beauty">
          <img src="https://images.unsplash.com/photo-1519699047748-de8e457a634e?auto=format&fit=crop&w=600&q=80" alt="Relaxing spa treatment setup" loading="lazy">
          <div class="overlay"><span>Beauty Treatment</span></div>
        </div>
        <div class="masonry-item" data-category="bridal">
          <img src="https://images.unsplash.com/photo-1519415387722-a1c3bbef716c?auto=format&fit=crop&w=600&q=80" alt="Bridal hairstyling session" loading="lazy">
          <div class="overlay"><span>Bridal Gallery</span></div>
        </div>
        <div class="masonry-item" data-category="results">
          <img src="https://images.unsplash.com/photo-1541533848490-bc8115cd6522?auto=format&fit=crop&w=600&q=80" alt="Client hair wash and result" loading="lazy">
          <div class="overlay"><span>Client Result</span></div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="section tint">
    <div class="container">
      <div class="cta-band reveal">
        <svg class="strands" viewBox="0 0 800 300" preserveAspectRatio="none"><path d="M0 250 Q 200 150 400 220 T 800 180" stroke="#2DD4BF" stroke-width="1.5" fill="none"/></svg>
        <div class="cta-band-inner">
          <div>
            <h2>Like what you see?</h2>
            <p>Book your appointment and let's create your next transformation.</p>
          </div>
          <div class="cta-actions">
            <a href="/contact#book" class="btn btn-primary">Book Appointment</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- LIGHTBOX -->
<div class="lightbox">
  <button class="lightbox-close" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
  <button class="lightbox-prev" aria-label="Previous image"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
  <button class="lightbox-next" aria-label="Next image"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
  <figure>
    <img src="" alt="">
    <figcaption></figcaption>
  </figure>
</div>
</Layout>
